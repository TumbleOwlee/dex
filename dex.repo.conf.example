# dex repository config  —  place at <git-root>/.dex.conf
#
# This file is committed to the repository and shared with the whole team.
# It provides the default Docker image, profile settings, and alias definitions
# for the project.  Individual developers can override any setting by creating
# a personal local project config in ~/.dex.d/ (higher priority).
#
# Config hierarchy (highest priority first):
#   1. ~/.dex.d/<name>.conf   — personal local overrides (not committed)
#   2. <git-root>/.dex.conf   — this file (committed, team defaults)
#   3. ~/.dex.conf            — global personal defaults (optional)
#
# ──────────────────────────────────────────────────────────────────────────────
# [project] section
# Controls script-level defaults for this repository.
# ──────────────────────────────────────────────────────────────────────────────
[project]
# Use this profile by default when running inside this repository.
profile     = default

# Image to use when no profile-level image is set.
# image     = my-org/my-project:latest

# Dockerfile to build the image from (path relative to this file).
# dockerfile = Dockerfile

# ──────────────────────────────────────────────────────────────────────────────
# Profile section
# Defines or overrides the active profile's Docker image and environment.
# ──────────────────────────────────────────────────────────────────────────────
[default]
image       = my-org/my-project:latest

# Optional: comma-separated host:container port mappings (applied at container
# creation time; use --restart to recreate an existing container).
# ports     = 8080:8080,5432:5432

# Optional: environment variables injected into every command.
# Supports plain values, host pass-through, and command substitution:
#   env = KEY=value, HOST_VAR, JIRA=$(git branch --show-current | grep -oP 'PRJ-\d+')
# env       =

# ──────────────────────────────────────────────────────────────────────────────
# Alias sections  [alias:<name>]
# Aliases defined here are available in all profiles.
# To scope an alias to a specific profile, use [alias:<profile>:<name>].
# ──────────────────────────────────────────────────────────────────────────────

[alias:build]
cmd         = cmake --build build

[alias:test]
cmd         = ctest --test-dir build --output-on-failure

[alias:shell]
cmd         = bash
interactive = true

# Pipeline alias: runs configure → build → test in order, stops on first failure.
[alias:ci]
pipeline    = configure, build, test

[alias:configure]
cmd         = cmake -S . -B build -DCMAKE_BUILD_TYPE=Release

# Profile-scoped alias example: only available when the 'clang' profile is active.
# [alias:clang:build]
# cmd       = cmake --build build --target all
# env       = CC=clang,CXX=clang++
